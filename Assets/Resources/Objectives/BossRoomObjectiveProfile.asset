  m_Name: BossRoomObjectiveProfile
  m_EditorClassIdentifier: Assembly-CSharp::ObjectiveProfile
  _roomType: 3
  _title: "\u0411\u043e\u0441\u0441: {BossPhase}"
  _steps:
  - _text: "\u0414\u043e\u0432\u0435\u0441\u0442\u0438 \u0431\u043e\u0441\u0441\u0430 \u0434\u043e \u0432\u0442\u043e\u0440\u043e\u0439 \u0444\u0430\u0437\u044b"
    _description: "\u0411\u0435\u0439\u0442\u0435 \u0431\u043e\u0441\u0441\u0430 \u043d\u0430 {AttackKey}, \u043b\u043e\u0432\u0438\u0442\u0435 \u043e\u043a\u043d\u0430 \u043f\u043e\u0441\u043b\u0435 \u0435\u0433\u043e \u0430\u0442\u0430\u043a \u0438 \u0434\u0435\u0440\u0436\u0438\u0442\u0435 \u0434\u0438\u0441\u0442\u0430\u043d\u0446\u0438\u044e."
    _trigger: 9
    _targetId: PhaseTwo
  - _text: "\u0414\u043e\u0432\u0435\u0441\u0442\u0438 \u0431\u043e\u0441\u0441\u0430 \u0434\u043e \u0442\u0440\u0435\u0442\u044c\u0435\u0439 \u0444\u0430\u0437\u044b"
    _description: "\u041d\u0430 \u0432\u0442\u043e\u0440\u043e\u0439 \u0444\u0430\u0437\u0435 \u043d\u0435 \u0441\u0442\u043e\u0439\u0442\u0435 \u043f\u043e\u0434 \u043a\u043e\u0432\u0448\u043e\u043c \u0438 \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u0439\u0442\u0435 \u0434\u0430\u0432\u0438\u0442\u044c \u0430\u0442\u0430\u043a\u0430\u043c\u0438."
    _trigger: 9
    _targetId: PhaseThree
  - _text: "\u041f\u043e\u0431\u0435\u0434\u0438\u0442\u044c \u0431\u043e\u0441\u0441\u0430"
    _description: "\u0414\u043e\u0431\u0435\u0439\u0442\u0435 \u0431\u043e\u0441\u0441\u0430 \u043d\u0430 \u0444\u0438\u043d\u0430\u043b\u044c\u043d\u043e\u0439 \u0444\u0430\u0437\u0435. \u042d\u0442\u043e \u043a\u043e\u043d\u0435\u0446 \u0437\u0430\u0431\u0435\u0433\u0430."
    _trigger: 7
    _targetId: 
