  m_Script: {fileID: 11500000, guid: a72b2a9e4d7447f69c92a68b7d70f003, type: 3}
  m_Name: CombatRoomObjectiveProfile
  m_EditorClassIdentifier: Assembly-CSharp::ObjectiveProfile
  _roomType: 1
  _title: "\u0411\u043e\u0435\u0432\u0430\u044f \u043a\u043e\u043c\u043d\u0430\u0442\u0430: {EnemyProgress}"
  _steps:
  - _text: "\u0417\u0430\u0447\u0438\u0441\u0442\u0438\u0442\u044c \u043a\u043e\u043c\u043d\u0430\u0442\u0443"
    _description: "\u041a\u043e\u0433\u0434\u0430 \u0434\u0432\u0435\u0440\u0438 \u0437\u0430\u043a\u0440\u044b\u043b\u0438\u0441\u044c, \u0443\u0431\u0435\u0439\u0442\u0435 \u0432\u0441\u0435\u0445 \u0432\u0440\u0430\u0433\u043e\u0432. \u0410\u0442\u0430\u043a\u0443\u0439\u0442\u0435 \u043d\u0430 {AttackKey} \u0438 \u0441\u043b\u0435\u0434\u0438\u0442\u0435 \u0437\u0430 \u0434\u0438\u0441\u0442\u0430\u043d\u0446\u0438\u0435\u0439."
    _trigger: 6
    _targetId: 
  - _text: "\u0420\u0443\u043a\u043e\u043f\u0430\u0448\u043d\u044b\u0435: \u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c {MeleeLeft}/{MeleeTotal}"
    _description: "\u0420\u0443\u043a\u043e\u043f\u0430\u0448\u043d\u044b\u0435 \u043b\u0435\u0437\u0443\u0442 \u0432\u0431\u043b\u0438\u0437\u0438. \u0414\u0435\u0440\u0436\u0438\u0442\u0435 \u0438\u0445 \u043d\u0430 \u0434\u0438\u0441\u0442\u0430\u043d\u0446\u0438\u0438 \u0438 \u0431\u0435\u0439\u0442\u0435 \u043d\u0430 {AttackKey}."
    _trigger: 8
    _targetId: melee
  - _text: "\u0411\u043e\u043c\u0431\u0435\u0440\u044b: \u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c {BomberLeft}/{BomberTotal}"
    _description: "\u0411\u043e\u043c\u0431\u0435\u0440\u044b \u043e\u043f\u0430\u0441\u043d\u044b \u0432\u0431\u043b\u0438\u0437\u0438. \u041f\u043e\u0434\u043f\u0443\u0441\u043a\u0430\u0439\u0442\u0435 \u0438\u0445 \u043e\u0441\u0442\u043e\u0440\u043e\u0436\u043d\u043e, \u0431\u0435\u0439\u0442\u0435 \u043d\u0430 {AttackKey} \u0438 \u043e\u0442\u0445\u043e\u0434\u0438\u0442\u0435."
    _trigger: 8
    _targetId: bomber
  - _text: "\u0414\u0440\u043e\u043d\u044b: \u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c {DroneLeft}/{DroneTotal}"
    _description: "\u0414\u0440\u043e\u043d\u044b \u0434\u0435\u0440\u0436\u0430\u0442 \u0434\u0438\u0441\u0442\u0430\u043d\u0446\u0438\u044e. \u0421\u0431\u043b\u0438\u0436\u0430\u0439\u0442\u0435\u0441\u044c \u0438\u043b\u0438 \u0441\u0442\u0440\u0435\u043b\u044f\u0439\u0442\u0435, \u043a\u043e\u0433\u0434\u0430 \u0435\u0441\u0442\u044c \u043e\u043a\u043d\u043e."
    _trigger: 8
    _targetId: drone
  - _text: "\u0422\u0443\u0440\u0440\u0435\u043b\u0438: \u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c {TurretLeft}/{TurretTotal}"
    _description: "\u0422\u0443\u0440\u0440\u0435\u043b\u0438 \u0432\u0435\u0434\u0443\u0442 \u043e\u0433\u043e\u043d\u044c \u043f\u043e \u043b\u0438\u043d\u0438\u0438. \u0412\u044b\u0445\u043e\u0434\u0438\u0442\u0435 \u0438\u0437-\u0437\u0430 \u0443\u043a\u0440\u044b\u0442\u0438\u044f \u0438 \u0431\u0435\u0439\u0442\u0435 \u043d\u0430 {AttackKey}."
    _trigger: 8
    _targetId: turret
  - _text: "\u041f\u0435\u0440\u0435\u0439\u0442\u0438 \u0432 \u0434\u0440\u0443\u0433\u0443\u044e \u043a\u043e\u043c\u043d\u0430\u0442\u0443"
    _description: "\u041f\u043e\u0441\u043b\u0435 \u0437\u0430\u0447\u0438\u0441\u0442\u043a\u0438 \u043a\u043e\u043c\u043d\u0430\u0442\u044b \u0434\u043e\u0439\u0434\u0438\u0442\u0435 \u0434\u043e \u0432\u044b\u0445\u043e\u0434\u0430 \u0438 \u043f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0435\u0440\u044c."
    _trigger: 4
    _targetId: 
